    },
    {
      "id": "3",
      "title": "مشاركة البيانات",
      "items": [
        { "text": "لا نقوم ببيع البيانات أو مشاركتها لأطراف غير ذات صلة. تتم المشاركة فقط مع جهات لازمة لتنفيذ الخدمة، وتشمل:", "type": "plain" },
        { "text": "مراكز الصيانة المعتمدة.", "type": "number" },
        { "text": "سائقي السطحات.", "type": "number" },
        { "text": "مزودي خدمات الدفع الإلكتروني والخدمات التشغيلية المرتبطة.", "type": "number" }
      ]
    },
    {
      "id": "4",
      "title": "حماية البيانات",
      "items": [
        { "text": "حفظ البيانات في أنظمة مؤمنة ومتوافقة مع معايير الحماية.", "type": "number" },
        { "text": "تشفير البيانات الحساسة أثناء النقل.", "type": "number" },
        { "text": "تقييد الوصول إلى البيانات ليقتصر على الأشخاص المخولين فقط.", "type": "number" }
      ]
    },
    {
      "id": "5",
      "title": "التعديلات على السياسة",
      "items": [
        {
          "text": "يجوز لتطبيق ترس تحديث سياسة الخصوصية في أي وقت. ويُعد استمرار استخدام التطبيق بعد نشر التعديلات موافقة ضمنية على السياسة المحدثة.",
          "type": "plain"
        }
